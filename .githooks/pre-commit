#!/bin/bash
# Pre-commit hook for NetworkX MCP Server
# Ensures code quality before allowing commits

set -e

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
FAILED=0

# Function to print colored output
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✅ $2${NC}"
    else
        echo -e "${RED}❌ $2${NC}"
        FAILED=1
    fi
}

# 1. Check for debugging artifacts (Python files only)
echo "Checking for debugging artifacts..."
PYTHON_STAGED=$(git diff --cached --name-only | grep '\.py$' || true)
if [ ! -z "$PYTHON_STAGED" ]; then
    if echo "$PYTHON_STAGED" | xargs grep -l "import pdb\|pdb.set_trace\|debugger" 2>/dev/null; then
        echo -e "${RED}❌ Found debugging statements in staged files${NC}"
        echo "Please remove debugging code before committing."
        FAILED=1
    else
        echo -e "${GREEN}✅ No debugging artifacts found${NC}"
    fi
else
    echo -e "${GREEN}✅ No debugging artifacts found${NC}"
fi

# 2. Check for sensitive information
echo "Checking for sensitive information..."
SENSITIVE_PATTERNS="password\|secret\|token\|api[_-]key\|apikey\|AWS_ACCESS_KEY\|AWS_SECRET"
if git diff --cached --name-only | xargs grep -iE "$SENSITIVE_PATTERNS" 2>/dev/null | grep -v "# noqa: S"; then
    echo -e "${YELLOW}⚠️  Potential sensitive information detected${NC}"
    echo "Please review the above matches and ensure no secrets are being committed."
    if [ -t 0 ]; then
        read -p "Continue with commit? (y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
fi

# 3. Run ruff formatting check
echo "Checking code formatting with ruff..."
if command -v ruff &> /dev/null; then
    ruff format --check . &>/dev/null
    RUFF_FMT_RESULT=$?
    print_status $RUFF_FMT_RESULT "Code formatting (ruff)"

    if [ $RUFF_FMT_RESULT -ne 0 ]; then
        echo "Run 'ruff format .' to fix formatting issues"
    fi
else
    echo -e "${YELLOW}⚠️  ruff not installed - skipping format check${NC}"
fi

# 4. Run ruff linting
echo "Running linter checks..."
if command -v ruff &> /dev/null; then
    ruff check . --quiet
    RUFF_LINT_RESULT=$?
    print_status $RUFF_LINT_RESULT "Linting (ruff)"

    if [ $RUFF_LINT_RESULT -ne 0 ]; then
        echo "Run 'ruff check . --fix' to fix some issues automatically"
    fi
else
    echo -e "${YELLOW}⚠️  ruff not installed - skipping lint check${NC}"
fi

# 5. Run type checking with mypy
echo "Running type checks..."
if command -v mypy &> /dev/null; then
    mypy src/networkx_mcp/ --ignore-missing-imports --no-error-summary > /dev/null 2>&1
    MYPY_RESULT=$?
    print_status $MYPY_RESULT "Type checking (mypy)"
else
    echo -e "${YELLOW}⚠️  mypy not installed - skipping type check${NC}"
fi

# 6. Run security checks with bandit
echo "Running security checks..."
if command -v bandit &> /dev/null; then
    bandit -r src/networkx_mcp/ -ll --quiet 2>/dev/null
    print_status $? "Security scan (bandit)"
else
    echo -e "${YELLOW}⚠️  bandit not installed - skipping security check${NC}"
fi

# 7. Check file sizes
echo "Checking file sizes..."
LARGE_FILES=$(git diff --cached --name-only | xargs -I {} sh -c 'test -f "{}" && stat -f%z "{}" 2>/dev/null || stat -c%s "{}" 2>/dev/null' | awk '$1 > 1048576')
if [ ! -z "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️  Large files detected (>1MB)${NC}"
    git diff --cached --name-only | xargs -I {} sh -c 'test -f "{}" && ls -lh "{}"' | awk '$5 ~ /[0-9]+M/'
    if [ -t 0 ]; then
        read -p "Continue with large files? (y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
fi

# 8. Run tests for changed files
echo "Running tests for changed files..."
CHANGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | grep -v '__pycache__' || true)
if [ ! -z "$CHANGED_PY_FILES" ]; then
    if command -v pytest &> /dev/null; then
        # Run only tests related to changed files
        TEST_FILES=""
        for file in $CHANGED_PY_FILES; do
            base=$(basename "$file" .py)
            test_file="tests/working/test_${base}.py"
            if [ -f "$test_file" ]; then
                TEST_FILES="$TEST_FILES $test_file"
            fi
        done

        if [ ! -z "$TEST_FILES" ]; then
            pytest $TEST_FILES --quiet --tb=no
            print_status $? "Related tests"
        fi
    else
        echo -e "${YELLOW}⚠️  pytest not installed - skipping test check${NC}"
    fi
fi

# 9. Check Python syntax
echo "Checking Python syntax..."
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ ! -z "$PYTHON_FILES" ]; then
    for file in $PYTHON_FILES; do
        python -m py_compile "$file" 2>/dev/null
        if [ $? -ne 0 ]; then
            echo -e "${RED}❌ Syntax error in $file${NC}"
            FAILED=1
        fi
    done
    if [ $FAILED -eq 0 ]; then
        echo -e "${GREEN}✅ Python syntax check passed${NC}"
    fi
fi

# 10. Check for merge conflicts
echo "Checking for merge conflict markers..."
if git diff --cached --name-only | xargs grep -E "^(<<<<<<<|=======|>>>>>>>)" 2>/dev/null; then
    echo -e "${RED}❌ Merge conflict markers found${NC}"
    FAILED=1
else
    echo -e "${GREEN}✅ No merge conflict markers${NC}"
fi

# Final status
echo ""
if [ $FAILED -ne 0 ]; then
    echo -e "${RED}❌ Pre-commit checks failed!${NC}"
    echo "Please fix the issues above and try again."
    exit 1
else
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
fi

exit 0
